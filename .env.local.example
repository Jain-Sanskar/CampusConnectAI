# Copy this file to .env.local and fill in your own values.
# .env.local is git-ignored and is loaded automatically by ./scripts/start.sh
# so secrets never get committed and you don't have to export them each time.

# Free Gemini key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the model (defaults to gemini-flash-latest).
# Reliable free-tier options: gemini-2.0-flash, gemini-1.5-flash
# GEMINI_MODEL=gemini-2.0-flash

# Optional: override the seeded admin password.
# ADMIN_PASSWORD=change-me
